[flake8]
max-line-length = 120

exclude =
    .git,
    __pycache__,
    .pytest_cache,
    venv,
    .venv,
    build,
    dist,
    data,
    reports

# W291: trailing whitespace (fires on docstring comment lines)
# W293: whitespace before block comment
# W503: line break before binary operator
ignore = W291,W293,W503

statistics = True
