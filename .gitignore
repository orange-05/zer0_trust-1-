# .gitignore — Files NOT to commit to Git
# =========================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyc
.Python
build/
dist/
*.egg-info/

# Virtual environment
venv/
.venv/
env/

# Testing
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# Environment variables — NEVER commit these
.env
.env.*
*.env

# Terraform
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/*.tfvars      # Contains secrets — gitignore!
terraform/.terraform.lock.hcl

# Data files — these contain runtime data, not source code
# Uncomment if you don't want to commit initial empty JSON files:
# data/*.json

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker
*.tar

# Reports (generated by CI)
reports/*.json
